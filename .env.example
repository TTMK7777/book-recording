# --- Supabase ---
# Supabase ダッシュボードの Settings > API から取得
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Database (Drizzle direct connection) ---
# Supabase Postgres の "Connection pooling" モード URL を推奨
# 例: postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=

# --- Google Books API (任意) ---
# 未設定でも基本検索は動作する。レート制限が気になる場合のみ設定
GOOGLE_BOOKS_API_KEY=

# --- Anthropic Claude (Phase 3 で使用) ---
ANTHROPIC_API_KEY=
